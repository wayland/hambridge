{
  "models": {
    "base-visca": {
      "topics": {
        "power/on": {
          "bytes": "01 04 00",
          "template": ["powerArgument"],
          "variables": { "powerArgument": "02" }
        },
        "power/off": {
          "bytes": "01 04 00 03"
        }
      }
    },
    "marshall-cv344": {
      "inherits": "base-visca",
      "topics": {
        "preset/call": {
          "bytes": "01 04 3F 02",
          "template": ["presetIndex"],
          "variables": { "presetIndex": "01" }
        }
      }
    }
  },
  "_note": "Wire order: [device]=0x80+viscaAddress from devices.json, then hex bytes, then one byte per template slot, then FF. Omit template/variables when bytes alone is the full middle. MQTT JSON keys match template slot names (case-insensitive); values 0–255 or hex strings."
}
