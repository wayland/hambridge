{
  "mqtt": {
    "host": "localhost",
    "port": 1883,
    "tls": false,
    "username": null,
    "password": null,
    "clientId": "hambridge",
    "keepaliveSec": 30,
    "lwt": {
      "topic": "bridge/hambridge/status",
      "payload": "offline",
      "retain": true,
      "qos": 1
    },
    "birth": {
      "topic": "bridge/hambridge/status",
      "payload": "online",
      "retain": true,
      "qos": 1
    }
  },
  "log": {
    "level": "info",
    "format": "text"
  }
}
