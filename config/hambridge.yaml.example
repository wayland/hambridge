# HaMBridge — single YAML configuration.
# Copy to config/hambridge.yaml and edit. From a clone, run with an explicit path, e.g.:
#   ./build/hambridge --config ./config/hambridge.yaml
# Default discovery does not load ./config/hambridge.yaml by itself.
# Top-level keys: bridge, device_mappings, buses, endpoints (see Specification.md §3.0–§3.1).
# v0.4.1+: each bus uses transport, transport_configuration, protocol, and optional protocol_config.
# v0.4.2+: VISCA devices under endpoints[] (match.endpoint_type: device).
# v0.4.3+: Linux input under buses.*.protocol: evdev + endpoints[] (match.endpoint_type: controller, match.protocol: evdev).
#          Controller MQTT: controller/<slug>/event (endpoint slug). No top-level evdev: key.
# v0.4.4+: VISCA over UDP buses (transport: udp, protocol: visca) + device endpoints with udpHost/udpPort
#          (or bus defaultUdpHost/defaultUdpPort). Exactly one controller endpoint per UDP bus (match.protocol: visca).

bridge:
  mqtt:
    host: localhost
    port: 1883
    # TLS: boolean shorthand, or an object (Specification.md / ConfigurationGuide — MQTT TLS).
    # tls: false
    # tls:
    #   enabled: true
    #   caFile: /etc/hambridge/tls/ca.crt
    #   verifyPeer: true
    #   serverName: mqtt.example.invalid
    tls: false
    username: null
    password: null
    clientId: hambridge
    keepaliveSec: 30
    lwt:
      topic: bridge/hambridge/status
      payload: offline
      retain: true
      qos: 1
    birth:
      topic: bridge/hambridge/status
      payload: online
      retain: true
      qos: 1
  log:
    level: info
    format: text

device_mappings:
  visca: mappings/visca.yaml

buses:
  rs485-1:
    transport: serial
    protocol: visca
    protocol_config: {}
    transport_configuration:
      port: /dev/ttyUSB0
      baud: 9600
      dataBits: 8
      parity: "N"
      stopBits: 1
  visca-udp-1:
    transport: udp
    protocol: visca
    protocol_config: {}
    transport_configuration:
      bindHost: "0.0.0.0"
      bindPort: 52381
      allowFrom: ["192.0.2.0/24"]
      defaultUdpHost: null
      defaultUdpPort: null
  evdev:
    transport: none
    protocol: evdev
    protocol_config:
      enabled: true
    transport_configuration: {}

endpoints:
  - match:
      endpoint_type: device
      bus: rs485-1
      deviceID: 1
    slug: camera_stage
    model: marshall-cv344
    scheduler:
      minInterCommandMs: 50
      maxQueueDepth: 50
  - match:
      endpoint_type: device
      bus: visca-udp-1
      deviceID: 1
    slug: camera_udp_stage
    model: marshall-cv344
    udpHost: "192.0.2.10"
    udpPort: 52381
  - match:
      endpoint_type: controller
      protocol: visca
      bus: visca-udp-1
    slug: visca_udp_listener
  - match:
      endpoint_type: controller
      protocol: evdev
      bus: evdev
      deviceNode: /dev/input/event0
    slug: example_keypad
    grabExclusive: false
