{
  "viscaMapping": "visca-mapping.json",
  "buses": {
    "rs485-1": {
      "port": "/dev/ttyUSB0",
      "baud": 9600,
      "dataBits": 8,
      "parity": "N",
      "stopBits": 1
    }
  },
  "devices": [
    {
      "slug": "camera_stage",
      "model": "marshall-cv344",
      "bus": "rs485-1",
      "viscaAddress": 1,
      "scheduler": {
        "minInterCommandMs": 50,
        "maxQueueDepth": 50
      }
    }
  ],
  "evdev": {
    "enabled": true,
    "inputs": [
      {
        "slug": "example_keypad",
        "deviceNode": "/dev/input/event0",
        "grabExclusive": false,
        "mqttTopic": "evdev/example_keypad/event"
      }
    ]
  },
  "_note": "Copy to devices.json. VISCA control topics: device/<slug>/<command> (e.g. device/camera_stage/preset/call). viscaAddress is VISCA peripheral id 1..7. Evdev default topic: evdev/<slug>/event. JSON field inputSlug in evdev events matches slug."
}
